# Naver account (optional when using `npm run login` manual session)
NAVER_ID=
NAVER_PASSWORD=

# Naver Cafe board URL that contains homework notices
# Example: https://cafe.naver.com/ca-fe/cafes/<cafeId>/menus/<menuId>
NAVER_CAFE_BOARD_URL=

# Runtime options
HEADLESS=true
REQUIRE_LOGIN=true
MAX_POSTS=5
RECENT_DAYS=2
TIME_ZONE=Asia/Seoul
PORT=4173

# Output files
OUTPUT_DIR=./public
DATA_FILE=./public/homework.json
HTML_FILE=./public/index.html
STATE_FILE=./.state/run-state.json
STORAGE_STATE_FILE=./.state/naver-storage-state.json
PAGE_TITLE=TopStar 영어학원 숙제 체크리스트
